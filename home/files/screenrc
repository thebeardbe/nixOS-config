# GNU Screen config — vim-style tab navigation with Ctrl+A
startup_message off
vbell off
bell_msg ""

# Tab bar at the bottom
hardstatus alwayslastline
hardstatus string '%{= kG} %{= kw}%-w%{= kG}%{+b}[ %n %t ]%{-b}%{= kw}%+w %{= kG} %{= kw}%= %{= kW}%Y-%m-%d %c'

# Terminal
term xterm-256color
defutf8 on
shell -$SHELL
defscrollback 10000

# Vim-style tab navigation with Ctrl+A prefix
bind h prev      # Ctrl+A h = previous tab
bind l next      # Ctrl+A l = next tab
bind k prev      # Ctrl+A k = previous tab
bind j next      # Ctrl+A j = next tab
bind 0 select 0  # Ctrl+A 0-9 = jump to tab
bind 1 select 1
bind 2 select 2
bind 3 select 3
bind 4 select 4
bind 5 select 5
bind 6 select 6
bind 7 select 7
bind 8 select 8
bind 9 select 9

# Start with 4 tabs
screen -t shell 0
screen -t shell 1
screen -t shell 2
screen -t shell 3
select 0
